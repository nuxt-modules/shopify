{
  "name": "@nuxtjs/shopify",
  "version": "0.8.0",
  "license": "MIT",
  "type": "module",
  "description": "Easily integrate Shopify with Nuxt 3 and 4 🚀",
  "packageManager": "pnpm@11.5.3",
  "workspaces": [
    "playgrounds/*",
    "template",
    "docs",
    "."
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nuxt-modules/shopify.git"
  },
  "homepage": "https://shopify.nuxtjs.org",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    },
    "./storefront": {
      "types": "./dist/clients/storefront.d.ts"
    },
    "./customer-account": {
      "types": "./dist/clients/customer-account.d.ts"
    },
    "./admin": {
      "types": "./dist/clients/admin.d.ts"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ],
      "storefront": [
        "./dist/clients/storefront.d.ts"
      ],
      "customer-account": [
        "./dist/clients/customer-account.d.ts"
      ],
      "admin": [
        "./dist/clients/admin.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "bin": {
    "init": "dist/cli.mjs"
  },
  "scripts": {
    "build": "nuxt-module-build build",
    "build:template": "pnpm --filter ./template build",
    "build:docs": "pnpm --filter ./docs build",
    "dev": "dotenv -e .env -- pnpm --filter playground-v4 dev",
    "dev:mock": "dotenv -e .env -- pnpm --filter playground-v4-mock dev",
    "dev:v3": "dotenv -e .env -- pnpm --filter playground-v3 dev",
    "dev:template": "dotenv -e .env -- pnpm --filter ./template dev",
    "dev:docs": "dotenv -e .env -- pnpm --filter ./docs dev",
    "lint": "eslint .",
    "typecheck": "vue-tsc --noEmit",
    "typecheck:playgrounds": "pnpm --filter \"./playgrounds/*\" typecheck",
    "typecheck:playground-v4": "pnpm --filter playground-v4 typecheck",
    "typecheck:playground-v4-mock": "pnpm --filter playground-v4-mock typecheck",
    "typecheck:playground-v3": "pnpm --filter playground-v3 typecheck",
    "typecheck:template": "pnpm --filter ./template typecheck",
    "typecheck:all": "vue-tsc --noEmit && pnpm --filter \"./playgrounds/*\" typecheck && pnpm --filter ./template typecheck",
    "knip": "knip",
    "test": "dotenv -e .env -- vitest run",
    "test:watch": "dotenv -e .env -- vitest watch",
    "test:coverage": "vitest run --coverage",
    "analyze": "pnpm --filter playground-v4 analyze",
    "prepack": "nuxt-module-build prepare && nuxt-module-build build",
    "prepare": "nuxt-module-build prepare",
    "prepare:dev": "nuxt-module-build --filter={./playgrounds/*,./template} prepare",
    "prepare:playgrounds": "pnpm --filter \"./playgrounds/*\" prepare",
    "prepare:template": "pnpm --filter ./template prepare",
    "prepare:docs": "pnpm --filter ./docs prepare",
    "prepare:all": "nuxt-module-build prepare && dotenv -e .env -- pnpm --filter \"./playgrounds/*\" --filter ./template --filter ./docs prepare",
    "cleanup": "pnpm --filter \"./playgrounds/*\" --filter ./template cleanup && nuxt cleanup",
    "cleanup:all": "pnpm --filter \"./playgrounds/*\" --filter ./template --filter ./docs cleanup && nuxt cleanup && rm -rf node_modules && rm -rf template/node_modules && rm -rf docs/node_modules && rm -rf playgrounds/playground/node_modules && rm -rf playgrounds/playground-mock/node_modules && rm -rf playgrounds/playground-v4/node_modules",
    "qa:all": "dotenv -e .env -- pnpm run lint && dotenv -e .env -- pnpm run typecheck:all && dotenv -e .env -- pnpm run test"
  },
  "dependencies": {
    "@graphql-codegen/cli": "^7.2.0",
    "@graphql-codegen/import-types-preset": "^4.0.1",
    "@graphql-codegen/introspection": "^6.1.0",
    "@graphql-codegen/plugin-helpers": "^7.1.0",
    "@graphql-codegen/typescript": "^6.1.0",
    "@graphql-yoga/render-graphiql": "^5.21.2",
    "@nuxt/kit": "^4.4.8",
    "@shopify/api-codegen-preset": "^2.0.1",
    "@shopify/graphql-client": "^1.4.2",
    "@shopify/graphql-codegen": "^0.1.0",
    "citty": "^0.2.2",
    "consola": "^3.4.2",
    "defu": "^6.1.7",
    "giget": "^3.3.0",
    "graphql-yoga": "^5.21.2",
    "h3": "^1.15.11",
    "lru-cache": "^11.5.2",
    "minimatch": "^10.2.5",
    "nitropack": "^2.13.4",
    "ohash": "^2.0.11",
    "scule": "^1.3.0",
    "ufo": "^1.6.4",
    "unstorage": "^1.17.5",
    "vue": "^3.5.39",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@graphql-tools/graphql-tag-pluck": "^8.3.33",
    "@nuxt/eslint-config": "^1.16.0",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.8",
    "@nuxt/test-utils": "^4.0.3",
    "@shopify/hydrogen": "^2026.4.4",
    "@shopify/hydrogen-react": "^2026.4.3",
    "@types/node": "^25.9.5",
    "@vitest/coverage-v8": "^4.1.10",
    "dotenv-cli": "^8.0.0",
    "eslint": "^10.6.0",
    "happy-dom": "^20.10.6",
    "knip": "^6.26.0",
    "nuxt": "^4.4.8",
    "typescript": "^6.0.3",
    "unbuild": "^3.6.1",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7"
  },
  "peerDependencies": {
    "@shopify/hydrogen": "*",
    "@shopify/hydrogen-react": "*"
  },
  "peerDependenciesMeta": {
    "@shopify/hydrogen": {
      "optional": true
    },
    "@shopify/hydrogen-react": {
      "optional": true
    }
  },
  "keywords": [
    "nuxt",
    "nuxt3",
    "nuxt4",
    "nuxtjs",
    "nuxt-module",
    "shopify",
    "ecommerce",
    "storefront",
    "storefront-api",
    "admin-api",
    "graphql",
    "typescript",
    "codegen"
  ],
  "engines": {
    "node": "^20.x || ^22.x || ^24.x"
  }
}
