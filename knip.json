{
  "$schema": "./node_modules/knip/schema.json",
  "tags": [
    "-lintignore"
  ],
  "ignoreWorkspaces": [
    "docs",
    "template"
  ],
  "workspaces": {
    ".": {
      "entry": [
        "src/module.ts",
        "src/cli.ts",
        "src/clients/*.d.ts",
        "src/runtime/**/*.ts",
        "test/**/*.test.ts"
      ],
      "project": [
        "src/**/*.ts"
      ],
      "ignoreDependencies": [
        "@graphql-codegen/import-types-preset",
        "@graphql-codegen/introspection",
        "@shopify/api-codegen-preset",
        "@graphql-tools/graphql-tag-pluck",
        "@shopify/hydrogen",
        "nuxt-auth-utils"
      ]
    },
    "playgrounds/playground-v3": {
      "entry": [
        "app/**/*.{ts,vue}",
        "server/**/*.ts",
        "graphql/**/*.ts"
      ],
      "project": [
        "**/*.{ts,vue}"
      ]
    },
    "playgrounds/playground-v4": {
      "entry": [
        "app/**/*.{ts,vue}",
        "server/**/*.ts",
        "graphql/**/*.ts"
      ],
      "project": [
        "**/*.{ts,vue}"
      ]
    },
    "playgrounds/playground-v4-mock": {
      "entry": [
        "app/**/*.{ts,vue}",
        "server/**/*.ts",
        "graphql/**/*.ts"
      ],
      "project": [
        "**/*.{ts,vue}"
      ]
    }
  }
}
